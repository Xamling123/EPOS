# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database - MySQL
DB_NAME=restaurant_db
DB_USER=root
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=3306

# For SQLite (development fallback)
USE_SQLITE=True

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Token Lifetimes (in minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# eSewa Payment Gateway Configuration
# ========================================
# Test/Demo Merchant Account (COMPLETELY FREE FOR TESTING):
#   Merchant Code: EPAYTEST
#   Merchant Secret: 8gBm/:&EnhH.1/q
#
# To get your own eSewa merchant account:
#   1. Visit: https://esewa.com.np/
#   2. Go to: Business/Merchant > Sign Up
#   3. Fill the merchant registration form
#   4. Get your credentials and update these settings
# ========================================

ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_MERCHANT_SECRET=8gBm/:&EnhH.1/q
ESEWA_USE_TEST=True

# eSewa URLs for payment redirect
ESEWA_RETURN_URL=http://localhost:5173/payment/success
ESEWA_FAILURE_URL=http://localhost:5173/payment/failure
ESEWA_VERIFY_ENDPOINT=http://localhost:8000/api/payments/esewa/verify

